CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_LIST_ITEM_LIMIT=300000
DRY_RUN=0
BLOCK_PAGE_ENABLED=0

# Experimental SNI based filtering. Set to 1 to enable.
BLOCK_BASED_ON_SNI=0

# Shared allowlist URLs (applied to all tiers). Newline-separated.
# ALLOWLIST_URLS=

# Per-tier blocklist/allowlist URLs and location IDs. Newline-separated.
# CORE_BLOCKLIST_URLS=
# CORE_ALLOWLIST_URLS=
# CORE_LOCATION_IDS=
# LITE_BLOCKLIST_URLS=
# LITE_ALLOWLIST_URLS=
# LITE_LOCATION_IDS=
# PRO_BLOCKLIST_URLS=
# PRO_ALLOWLIST_URLS=
# PRO_LOCATION_IDS=

# Optional Discord webhook URL for notifications.
# DISCORD_WEBHOOK_URL=

# Disable dotenv ads ("tips").
DOTENV_CONFIG_QUIET=true
